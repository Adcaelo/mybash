#Bashrc spécifique Projet

git_envs=("cloud" "payment" "site" "www")

function ggit {

    curr_dir=$(pwd)

    for git_env in "${git_envs[@]}"
    do
        echo "${1^} de ${git_env^}"
        echo "cd /home/come/web/$git_env"
        cd /home/come/web/$git_env
        echo "git $@"
        git $@
        echo #new line
    done

    cd $curr_dir
}


function git_cleanup_all {

    echo "Cleaning all branches merged on master"
    read -r -p "Are you sure? [y/N] " response
    if [[ "$response" =~ ^([yY][eE][sS]|[yY])+$ ]]
    then

        for git_env in "${git_envs[@]}"
        do
            echo "processing ${git_env^}"
            cd /home/come/web/$git_env
            git checkout master
            git fetch
            if [[ $(git branch --merged | egrep -v "(^\*|master)") ]]; then
                git branch --merged | egrep -v "(^\*|master)" | xargs git branch -d
            fi
        done
    else
        echo "Cancelling"
    fi
}


alias artisan="php artisan -vvv"
alias tinker="artisan tinker"

alias web="cd ~/web/"
alias www="cd ~/web/www/"
alias site="cd ~/web/site/"
alias payment="cd ~/web/payment/"
alias cloud="cd ~/web/cloud"
alias admin="cd ~/web/admin"

alias ggg="gulp"
